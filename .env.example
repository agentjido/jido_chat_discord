# Enable the live Discord integration test module.
# Accepted truthy values: 1, true, TRUE, yes, on
RUN_LIVE_DISCORD_TESTS=false

# Discord bot token (required when RUN_LIVE_DISCORD_TESTS=true)
DISCORD_BOT_TOKEN=

# Channel id used for live integration tests (required when RUN_LIVE_DISCORD_TESTS=true)
DISCORD_TEST_CHANNEL_ID=

# Optional: user id used for live DM coverage
DISCORD_TEST_USER_ID=

# Optional: reaction emoji used by the live reaction test
DISCORD_TEST_REACTION=👍
